[color]
  diff = auto
  status = auto
  branch = auto
  interactive = auto
  ui = true

[alias]
  fp = push -u origin HEAD
  pf = push --force-with-lease
  pull = pull --rebase
  d = diff
  dc = diff --cached
  dsf = "!f() { [ -z \"$GIT_PREFIX\" ] || cd \"$GIT_PREFIX\" && git diff --color \"$@\" | diff-so-fancy  | less --tabs=4 -RFX; }; f"
  dsfc = "!f() { [ -z \"$GIT_PREFIX\" ] || cd \"$GIT_PREFIX\" && git diff --cached --color \"$@\" | diff-so-fancy  | less --tabs=4 -RFX; }; f"
  s = status
  st = status
  sta = status
  stat = status
  co = checkout
  b = branch
  ci = commit -m
  ca = commit --amend
  a = add .
  pt = !"git push && git push --tags"
  g = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  ga = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --all
  graph = log --oneline --graph --decorate --all
  info = !cat .git/config
  i = info
  ei = !$EDITOR .git/config
  l = !eza -la --sort=modified
  lcb = "!f() { git fetch --prune && git branch --merged | grep -Ev \"(^\\*|master|main|dev)\"; }; f"
  cb = "!f() { git fetch --prune && git branch --merged | grep -Ev \"(^\\*|master|main|dev)\" | xargs git branch -d; }; f"

[pager]
  branch = false

[rerere]
  enabled = true

[fetch]
  prune = true

[diff]
  algorithm = histogram

[branch]
  sort = -committerdate

[core]
  excludesfile = {{ .chezmoi.homeDir }}/.gitignore

[pull]
	rebase = true

[init]
	defaultBranch = main

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[includeIf "gitdir:~/.local/share/chezmoi/"]
  path = ~/.gitconf/perso.config

{{ if eq .profile "work" }}
{{- /* Work profile: repositories are split between a personal and a professional
       directory, each using their own git identity and signing key. */ -}}
[includeIf "gitdir:~/Documents/repositories/perso/"]
  path = ~/.gitconf/perso.config

[includeIf "gitdir:~/Documents/repositories/work/"]
  path = ~/.gitconf/pro.config
{{ end -}}

{{ if ne .profile "work" }}
{{- /* Non-work profile: all repositories use the personal git identity. */ -}}
[includeIf "gitdir:~/Documents/repositories/"]
  path = ~/.gitconf/perso.config
{{ end -}}
