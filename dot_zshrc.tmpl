# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export LC_CTYPE=UTF-8

ZSH=$HOME/.oh-my-zsh

ZSH_THEME="powerlevel10k/powerlevel10k"

DEFAULT_USER=$(whoami)

setopt EXTENDED_HISTORY
setopt HIST_FIND_NO_DUPS

# Disabled plugins: asdf poetry history (history replaced by atuin)
plugins=(
  lp
  brew copyfile
  direnv
  docker
  eza fzf
  gh git git-extras
  mise
  mvn
  npm
  macos
  uv
  zsh-autosuggestions zsh-syntax-highlighting
)

# Profile-specific plugin augmentation
{{ if eq .profile "work" -}}
plugins+=(lppro)
{{- end }}

source $ZSH/oh-my-zsh.sh

[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

alias ssh="ssh -F ~/.ssh/config"
alias tf="terraform"
alias tg="terragrunt"
alias kc="kubectl"
alias k="kubectl"
alias git='LANG=en_GB git'
alias lzg="lazygit"
alias lzd="lazydocker"
alias rc="repos_clone"
alias rt="repo_track"
alias rti="repos_track_import"
alias oc="opencode"
alias ze="zellij"
alias cm="chezmoi"

export EDITOR=nvim
export GPG_TTY=$(tty)

# source ~/.iterm2_shell_integration.zsh

export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# Add this to get JetBrains commands (idea, pycharm, ...)
#export PATH="{{ .chezmoi.homeDir }}/.local/bin:$PATH"

### MANAGED BY RANCHER DESKTOP START (DO NOT EDIT)
export PATH="{{ .chezmoi.homeDir }}/.rd/bin:$PATH"
### MANAGED BY RANCHER DESKTOP END (DO NOT EDIT)

# Homebrew — supports both Apple Silicon (/opt/homebrew) and Intel (/usr/local)
if [[ -x "/opt/homebrew/bin/brew" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x "/usr/local/bin/brew" ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

eval "$(mise activate zsh)"
eval "$(zoxide init zsh)"
eval "$(direnv hook zsh)"
eval "$(atuin init zsh)"

# fzf — use fd as default command, enable key bindings
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
[[ -f "$(brew --prefix)/opt/fzf/shell/key-bindings.zsh" ]] && source "$(brew --prefix)/opt/fzf/shell/key-bindings.zsh"
