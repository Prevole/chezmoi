echo -e "\033]50;SetProfile=lp\a"

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export LC_CTYPE=UTF-8
export TERM=xterm-256color

ZSH=$HOME/.oh-my-zsh

ZSH_THEME="powerlevel10k/powerlevel10k"

DEFAULT_USER=$(whoami)

setopt EXTENDED_HISTORY
setopt HIST_FIND_NO_DUPS

HISTFILESIZE=
HISTSIZE=

# Disabled plugins: asdf poetry
plugins=(lp brew copyfile direnv docker eza fzf gh git git-extras history mise mvn npm macos uv vagrant zsh-autosuggestions zsh-syntax-highlighting{{ if eq .setupType "work" }} lppro{{ end }})

source $ZSH/oh-my-zsh.sh

[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

alias ssh="ssh -F ~/.ssh/config"
alias tf="terraform"
alias tg="terragrunt"
alias kc="kubectl"
alias k="kubectl"
alias git='LANG=en_GB git'
alias lzg="lazygit"
alias lzd="lazydocker"

export EDITOR=nvim
export GPG_TTY=$(tty)

export no_proxy='*'

# source ~/.iterm2_shell_integration.zsh

export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# https://github.com/pypa/setuptools/issues/2353#issuecomment-684452550
export SETUPTOOLS_USE_DISTUTILS=stdlib

# Add this to get JetBrains commands (idea, pycharm, ...)
#export PATH="/Users/prevole/.local/bin:$PATH"

### MANAGED BY RANCHER DESKTOP START (DO NOT EDIT)
export PATH="/Users/Prevole/.rd/bin:$PATH"
### MANAGED BY RANCHER DESKTOP END (DO NOT EDIT)

eval "$(/opt/homebrew/bin/brew shellenv)"
eval "$(mise activate zsh)"
