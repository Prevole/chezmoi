{{- $gitName := "Prevole" -}}
[user]
  name = {{ $gitName }}
  email = {{ .email }}
  signingkey = {{ onepasswordRead (printf "op://%s/%s - %s - ED25519/public key" .chezmoi.hostname $gitName .chezmoi.hostname) }}

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
  gpgsign = true

[github]
  user = "REDACTED_REDACTED"

[credential]
	helper =
	helper = osxkeychain
	helper = /usr/local/share/gcm-core/git-credential-manager

[credential "https://dev.azure.com"]
	useHttpPath = true
