{{- $op := onepasswordItemFields "3aoqom6nitkbg5qzs27oylie3i" -}}
[user]
  name = "{{- $op.username.value }}"
  email = "{{- $op.email.value }}"
  {{- /* The signing key title is built as "<github-username> - <hostname> - ED25519",
         matching the item title created by 04-ssh-keys.sh with the personal GitHub
         username. $op.username.value must match what was typed at the prompt. */}}
  signingkey = {{ onepasswordRead (printf "op://%s/%s - %s - ED25519/public key" .chezmoi.hostname $op.username.value .chezmoi.hostname) }}

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
  gpgsign = true

[github]
  user = "{{- $op.username.value }}"

[credential]
	helper =
	helper = osxkeychain
