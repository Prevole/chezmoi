{{- $profile := promptChoiceOnce . "profile" "Profile" (list "work" "lp" "sp") }}
{{- $fullSetup := promptChoiceOnce . "fullSetup" "Full setup (install all tools for this profile)?" (list "yes" "no") | eq "yes" }}

git:
  autoCommit: true
  autoPush: true

data:
  profile: {{ $profile }}
  fullSetup: {{ $fullSetup }}
