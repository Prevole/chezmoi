echo -e "\033]50;SetProfile=lp\a"

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export LC_CTYPE=UTF-8
export TERM=xterm-256color

ZSH=$HOME/.oh-my-zsh

ZSH_THEME="powerlevel10k/powerlevel10k"

DEFAULT_USER=$(whoami)

setopt EXTENDED_HISTORY
setopt HIST_FIND_NO_DUPS

HISTFILESIZE=
HISTSIZE=

# Disabled plugins: poetry
plugins=(lp brew copyfile direnv docker git git-extras history mvn npm macos vagrant zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

alias ssh="ssh -F ~/.ssh/config"
alias tf="terraform"
alias tg="terragrunt"
alias kc="kubectl"
alias k="kubectl"
alias git='LANG=en_GB git'

export EDITOR=VIM
export REPOS_ELIGIBLE_FILTERS=.git
export REPOS_BASEDIRS=:~/Documents/repositories/github:~/Documents/repositories/github-perso:~/Documents/repositories/private:~/Documents/repositories/mo:~/Documents/repositories/REDACTED
export GITENV_REPO=~/Documents/repositories/private/env
export GITENV_CONFIG=~/Documents/repositories/private/env/.gitenv.rb
export GPG_TTY=$(tty)

export no_proxy='*'

source ~/.iterm2_shell_integration.zsh

export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# https://github.com/pypa/setuptools/issues/2353#issuecomment-684452550
export SETUPTOOLS_USE_DISTUTILS=stdlib

# DISABLED: export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"

### MANAGED BY RANCHER DESKTOP START (DO NOT EDIT)
export PATH="/Users/Prevole/.rd/bin:$PATH"
### MANAGED BY RANCHER DESKTOP END (DO NOT EDIT)

eval "$(/opt/homebrew/bin/brew shellenv)"
