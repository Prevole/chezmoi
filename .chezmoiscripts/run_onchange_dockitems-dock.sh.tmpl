#!/usr/bin/env zsh
set -euo pipefail

# dconf.ini hash: {{ include "dockitems" | sha256sum }}
DOCK_ITEMS_FILE={{ joinPath .chezmoi.sourceDir "dockitems" | quote }}

dockutil --remove all

while IFS= read -r app_path || [[ -n "$app_path" ]]; do
  [[ -z "$app_path" ]] && continue
  [[ -d "$app_path" ]] || continue
  dockutil --add "$app_path"
done < "$DOCK_ITEMS_FILE"

dockutil --add "${HOME}/Downloads" --view fan --display folder --before "Trash"
