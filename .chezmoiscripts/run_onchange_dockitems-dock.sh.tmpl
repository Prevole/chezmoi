#!/usr/bin/env zsh
set -euo pipefail

# dock/{{ .profile }}.yaml hash: {{ include (printf "profiles/%s/.chezmoidata/dock.yaml" .profile) | sha256sum }}

echo "Clearing existing Dock items..."
dockutil --remove all --no-restart

{{- range .dock.apps }}
dockutil --add {{ . | quote }} --no-restart
{{- end }}

dockutil --add "${HOME}/Downloads" --view fan --display folder --no-restart

killall Dock || true
