# ---------------------------------------------------------------------------
# Theme
# ---------------------------------------------------------------------------
# Active theme: Catppuccin Mocha
# Other good ones (uncomment to switch, ghostty +list-themes to browse):
#
# theme = Gruvbox Dark
# theme = Gruvbox Dark Hard
# theme = TokyoNight Storm
# theme = Rose Pine
# theme = Rose Pine Moon
# theme = Atom One Dark

theme = Catppuccin Mocha

# ---------------------------------------------------------------------------
# Font
# ---------------------------------------------------------------------------
font-family = MesloLGM Nerd Font
font-size = 13

# ---------------------------------------------------------------------------
# Window
# ---------------------------------------------------------------------------
background-opacity = 0.80
background-blur = 20

# Remove window decorations (title bar) — zellij provides its own UI
# window-decoration = false

# ---------------------------------------------------------------------------
# Shell integration
# ---------------------------------------------------------------------------
# Let Ghostty handle shell integration (cursor shape at prompt, etc.)
shell-integration = zsh

# ---------------------------------------------------------------------------
# Command
# ---------------------------------------------------------------------------
# Default: launch $SHELL (zsh).
# To launch zellij manually: just type `zellij` in the prompt.
# command = /opt/homebrew/bin/zellij

# ---------------------------------------------------------------------------
# Keyboard
# ---------------------------------------------------------------------------
# Treat macOS Option key as Alt for readline/zsh word navigation
# (Alt+left/right to jump words, Alt+backspace to delete word, etc.)
# "left" applies only to the left Option key, keeping right Option for
# macOS special characters (accents, symbols).
macos-option-as-alt = left

# ---------------------------------------------------------------------------
# Cursor
# ---------------------------------------------------------------------------
cursor-style = bar
cursor-style-blink = false

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# Hide mouse cursor while typing
mouse-hide-while-typing = true

# Copy selection to system clipboard automatically
# Use Shift+drag to select when inside Zellij (bypasses Zellij mouse capture)
copy-on-select = clipboard

# Confirm before closing a window with a running process
confirm-close-surface = true
